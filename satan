import os
import sys
import subprocess

def main():
    # This script acts as the 'satan' entry point, calling the main CLI
    script_dir = os.path.dirname(os.path.abspath(__file__))
    cli_path = os.path.join(script_dir, "satan_cli", "main.py")
    
    if not os.path.exists(cli_path):
        print(f"Error: Satan CLI core not found at {cli_path}")
        sys.exit(1)
        
    cmd = [sys.executable, cli_path] + sys.argv[1:]
    subprocess.run(cmd)

if __name__ == "__main__":
    main()
